VITE_APP_URL=http://localhost:3000

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_FORCE_DEMO_MODE=false

# Optional live Supabase RLS test credentials for a non-admin test user.
TEST_PUBLIC_EMAIL=user@nigeria.ng
TEST_PUBLIC_PASSWORD=user123

# Mapbox
VITE_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token

# Supabase Edge Functions read these server-side secrets.
# Do not expose these as VITE_ variables in the browser.
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=Carefinder <carefinder@your-domain.com>
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
